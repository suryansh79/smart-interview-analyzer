# ============================================
# Smart Interview Analyzer — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.sample .env

# ------- PostgreSQL -------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=interview_analyzer
DB_USERNAME=postgres
DB_PASSWORD=changeme

# ------- JWT -------
# Must be at least 256 bits (32+ characters) for HS256
JWT_SECRET=your-jwt-secret-min-32-chars

# ------- AWS S3 -------
AWS_ACCESS_KEY=your-aws-access-key-here
AWS_SECRET_KEY=your-aws-secret-key-here
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=smart-interview-analyzer-audio-2026

# ------- Flask AI Service -------
# In Docker Compose, use http://ai-service:5000
# For local dev, use http://localhost:5000
FLASK_SERVICE_URL=http://ai-service:5000
